<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Automation Suite" parallel="false" thread-count="2">

    <listeners>
        <listener class-name="com.expandtest.listeners.TestListener"/>
        <listener class-name="com.expandtest.listeners.RetryListener"/>
    </listeners>

    <test name="Login Tests">
        <classes>
            <class name="com.expandtest.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Notes Tests">
        <classes>
            <class name="com.expandtest.tests.NotesTest"/>
        </classes>
    </test>

    <test name="Form Interaction Tests">
        <classes>
            <class name="com.expandtest.tests.FormInteractionsTest"/>
        </classes>
    </test>

    <test name="Alerts Tests">
        <classes>
            <class name="com.expandtest.tests.AlertsTest"/>
        </classes>
    </test>

    <test name="Form Validations Tests">
        <classes>
            <class name="com.expandtest.tests.FormValidationsTest"/>
        </classes>
    </test>

</suite>